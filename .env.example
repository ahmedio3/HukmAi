# ============================================================
# HukmAi - Gemini API Keys Configuration
# ============================================================
# 
# كيفية الحصول على المفاتيح:
# 1. اذهب إلى https://aistudio.google.com/apikey
# 2. سجل الدخول بحساب Google الخاص بك
# 3. اضغط على "Create API Key"
# 4. اختر مشروع Google Cloud أو أنشئ مشروع جديد
# 5. انسخ المفتاح (يبدأ بـ AIzaSy...)
#
# يمكنك استخدام نفس المفتاح للـ 3 متغيرات (أو مفاتيح مختلفة لكل واحد)
# ============================================================

# المفتاح الرئيسي لتوجيه الأسئلة (المرحلة 1-3)
API_KEY_ROUTER_MAIN=AIzaSy...

# مفتاح احتياطي للتوجيه (اختياري - اتركه فارغاً إن لم ترد)
API_KEY_ROUTER_FALLBACK=

# المفتاح الخاص بتوليد الإجابة النهائية (المرحلة 4)
API_KEY_ANSWER=AIzaSy...
